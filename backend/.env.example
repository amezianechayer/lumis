ENV=development
PORT=8080

# Database
DATABASE_URL=postgresql://lumis:lumis@localhost:5432/lumis

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=30

# CORS — comma-separated allowed origins. Use "*" only in development.
# In production set this to your web origins, e.g. https://app.lumis.com
CORS_ALLOWED_ORIGINS=*

# Transactional email (password reset / verification)
# Leave RESEND_API_KEY empty in dev — emails are logged to the console instead.
RESEND_API_KEY=
EMAIL_FROM=Lumis <onboarding@resend.dev>
# Base URL used to build email links. Leave empty to use the app deep link (lumis://...).
APP_URL=

# Social login — id token audiences (comma-separated) accepted from the apps.
# Apple: your app bundle id (the audience of Sign in with Apple identity tokens).
APPLE_CLIENT_IDS=com.lumis.app
# Google: the OAuth client IDs used by the app (iOS + Android + web client ids).
GOOGLE_CLIENT_IDS=

# AI — No Anthropic!
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
REPLICATE_API_TOKEN=r8_...

# Cloudflare R2
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=lumis-photos
CLOUDFLARE_R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PREMIUM_PRICE_ID=price_...

# Rate limiting
FREE_ANALYSIS_LIMIT=10
PREMIUM_ANALYSIS_LIMIT=50
