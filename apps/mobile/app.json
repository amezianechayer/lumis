{
  "expo": {
    "name": "Lumis",
    "slug": "lumis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lumis.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Lumis needs camera access to analyze your skin and face.",
        "NSPhotoLibraryUsageDescription": "Lumis needs photo library access to analyze uploaded photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.lumis.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-web-browser",
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Lumis needs camera access to analyze your skin and face."
        }
      ],
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lumis utilise ta position pour te donner un conseil skincare adapté à la météo et l'index UV."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Lumis needs access to save your try-on photos.",
          "savePhotosPermission": "Lumis needs access to save your try-on photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "lumis",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "15b7c5e1-00d8-49d2-b047-ea1a79daa5d1"
      }
    },
    "owner": "darkam"
  }
}
