EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google Sign-In OAuth client IDs (from Google Cloud Console).
# These become the "aud" of the id token — add the same values to the backend's
# GOOGLE_CLIENT_IDS. Apple Sign-In needs no client id here (uses the bundle id).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
